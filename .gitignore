# Compiled
system/target/
pipeline/__pycache__/
pipeline/**/__pycache__/
*.pyc

# Keys and secrets (NEVER commit)
*.key
.env
.env.*

# Raw data (too large for git, download via bulk_sources.py)
pipeline/data/raw/
pipeline/data/normalized/

# Provenance manifests (generated by system, can be re-created)
system/provenance/

# Sealed governance artifacts — regenerable from their plaintext source via
# `aion-medsafe seal-policy` / `seal-graph`. The YAML/NDJSON source is committed.
system/policy/*.aion

# Human review decision log — authoritative operational state (NOT regenerable;
# the sealed hash chain is the audit trail). Back up separately, like a database.
system/decisions/

# Registry contains only public keys — safe to commit
# system/.aion/medsafe.registry.json  ← intentionally NOT ignored

# But the signing key must never be committed
system/.aion/pipeline.key

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Virtual environments
.venv/
venv/
